<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="SpotDesk.UI.Dialogs.OAuthConnectDialog"
        Title="Connect to GitHub"
        Width="420" SizeToContent="Height"
        MinHeight="260"
        CanResize="False"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BgElevatedBrush}">

  <StackPanel Margin="32" Spacing="20" VerticalAlignment="Center">

    <TextBlock Text="Connect SpotDesk to GitHub"
               FontSize="18" FontWeight="Medium"
               Foreground="{DynamicResource TextPrimaryBrush}"/>

    <TextBlock Text="Your vault is encrypted using your GitHub identity.
No master password required. Your credentials never leave your devices."
               FontSize="13"
               Foreground="{DynamicResource TextSecondaryBrush}"
               TextWrapping="Wrap"/>

    <!-- ── Initial choice panel ─────────────────────────────────── -->
    <StackPanel x:Name="InitialPanel" Spacing="10">
      <Button x:Name="GitHubButton"
              Content="Connect with GitHub"
              Classes="primary-button"
              HorizontalAlignment="Stretch"
              HorizontalContentAlignment="Center"/>

      <Button x:Name="MasterPasswordButton"
              Content="Use master password instead"
              Background="Transparent"
              Foreground="{DynamicResource TextSecondaryBrush}"
              BorderThickness="0" FontSize="12"
              HorizontalAlignment="Center"/>
    </StackPanel>

    <!-- ── GitHub Device Flow panel ─────────────────────────────── -->
    <StackPanel x:Name="GitHubFlowPanel" IsVisible="False" Spacing="12">
      <TextBlock Text="1. Your browser will open github.com/activate"
                 FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}"/>
      <TextBlock Text="2. Enter this code when prompted:"
                 FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}"/>
      <Border Background="{DynamicResource BgSurfaceBrush}"
              CornerRadius="8" Padding="16,10"
              HorizontalAlignment="Center">
        <TextBlock x:Name="DeviceCodeLabel"
                   FontSize="28" FontWeight="Bold" LetterSpacing="4"
                   FontFamily="{DynamicResource FontMono}"
                   Foreground="{DynamicResource AccentTextBrush}"
                   HorizontalAlignment="Center"/>
      </Border>
      <TextBlock x:Name="FlowStatusLabel"
                 FontSize="12" HorizontalAlignment="Center"
                 Foreground="{DynamicResource TextSecondaryBrush}"
                 TextWrapping="Wrap"/>
      <Button x:Name="CancelFlowButton"
              Content="Cancel"
              Background="{DynamicResource BgSurfaceBrush}"
              Foreground="{DynamicResource TextPrimaryBrush}"
              CornerRadius="6" Padding="16,8"
              HorizontalAlignment="Center"/>
    </StackPanel>

  </StackPanel>
</Window>
