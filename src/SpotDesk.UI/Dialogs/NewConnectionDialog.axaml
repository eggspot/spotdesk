<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:SpotDesk.UI.ViewModels"
        x:Class="SpotDesk.UI.Dialogs.NewConnectionDialog"
        x:DataType="vm:NewConnectionDialogViewModel"
        Title="{Binding Title}"
        Width="480" SizeToContent="Height"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BgElevatedBrush}">

  <StackPanel Margin="24" Spacing="16">

    <!-- Protocol selector -->
    <StackPanel Spacing="6">
      <TextBlock Text="Protocol" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"/>
      <StackPanel Orientation="Horizontal" Spacing="8">
        <ToggleButton Content="RDP" CornerRadius="6" Padding="12,6"
                      IsChecked="{Binding Protocol, Converter={x:Static vm:ProtocolConverter.Rdp}}"/>
        <ToggleButton Content="SSH" CornerRadius="6" Padding="12,6"
                      IsChecked="{Binding Protocol, Converter={x:Static vm:ProtocolConverter.Ssh}}"/>
        <ToggleButton Content="VNC" CornerRadius="6" Padding="12,6"
                      IsChecked="{Binding Protocol, Converter={x:Static vm:ProtocolConverter.Vnc}}"/>
      </StackPanel>
    </StackPanel>

    <!-- Name -->
    <StackPanel Spacing="6">
      <TextBlock Text="Name" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"/>
      <TextBox Text="{Binding Name}" Watermark="prod-web-01" FontSize="14"
               Background="{DynamicResource BgSurfaceBrush}"
               BorderBrush="{DynamicResource BorderDefaultBrush}"
               CornerRadius="6"/>
    </StackPanel>

    <!-- Host + Port -->
    <Grid ColumnDefinitions="*,120" ColumnSpacing="12">
      <StackPanel Grid.Column="0" Spacing="6">
        <TextBlock Text="Host" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"/>
        <TextBox Text="{Binding Host}" Watermark="192.168.1.100" FontSize="14"
                 FontFamily="{DynamicResource FontMono}"
                 Background="{DynamicResource BgSurfaceBrush}"
                 BorderBrush="{DynamicResource BorderDefaultBrush}"
                 CornerRadius="6"/>
      </StackPanel>
      <StackPanel Grid.Column="1" Spacing="6">
        <TextBlock Text="Port" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"/>
        <TextBox Text="{Binding Port}" Watermark="{Binding DefaultPortHint}" FontSize="14"
                 FontFamily="{DynamicResource FontMono}"
                 Background="{DynamicResource BgSurfaceBrush}"
                 BorderBrush="{DynamicResource BorderDefaultBrush}"
                 CornerRadius="6"/>
      </StackPanel>
    </Grid>

    <!-- Username -->
    <StackPanel Spacing="6">
      <TextBlock Text="Username" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"/>
      <TextBox Text="{Binding Username}"
               Watermark="DOMAIN\user  or  user@domain" FontSize="14"
               Background="{DynamicResource BgSurfaceBrush}"
               BorderBrush="{DynamicResource BorderDefaultBrush}"
               CornerRadius="6"/>
    </StackPanel>

    <!-- Password + remember option -->
    <StackPanel Spacing="6">
      <TextBlock Text="Password" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"/>
      <TextBox Text="{Binding Password}" PasswordChar="•"
               Watermark="leave blank to be prompted on connect" FontSize="14"
               Background="{DynamicResource BgSurfaceBrush}"
               BorderBrush="{DynamicResource BorderDefaultBrush}"
               CornerRadius="6"/>
      <CheckBox Content="Remember password (auto-connect)"
                IsChecked="{Binding RememberPassword}"
                Foreground="{DynamicResource TextSecondaryBrush}"
                FontSize="12"/>
    </StackPanel>

    <!-- Group + Tags -->
    <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
      <StackPanel Grid.Column="0" Spacing="6">
        <TextBlock Text="Group" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"/>
        <TextBox Text="{Binding Group}" Watermark="Default" FontSize="14"
                 Background="{DynamicResource BgSurfaceBrush}"
                 BorderBrush="{DynamicResource BorderDefaultBrush}"
                 CornerRadius="6"/>
      </StackPanel>
      <StackPanel Grid.Column="1" Spacing="6">
        <TextBlock Text="Tags" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"/>
        <TextBox Text="{Binding Tags}" Watermark="web, prod" FontSize="14"
                 Background="{DynamicResource BgSurfaceBrush}"
                 BorderBrush="{DynamicResource BorderDefaultBrush}"
                 CornerRadius="6"/>
      </StackPanel>
    </Grid>

    <!-- Advanced -->
    <Expander Header="Advanced" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="13">
      <StackPanel Spacing="8" Margin="0,8,0,0">

        <!-- SSH key path (SSH only) -->
        <StackPanel Spacing="4" IsVisible="{Binding IsSsh}">
          <TextBlock Text="SSH key path (optional)" FontSize="12"
                     Foreground="{DynamicResource TextSecondaryBrush}"/>
          <TextBox Text="{Binding SshKeyPath}" Watermark="~/.ssh/id_ed25519"
                   FontFamily="{DynamicResource FontMono}"
                   Background="{DynamicResource BgSurfaceBrush}" CornerRadius="6"/>
        </StackPanel>

        <!-- RDP resolution -->
        <Grid ColumnDefinitions="*,*" ColumnSpacing="12" IsVisible="{Binding IsRdp}">
          <StackPanel Grid.Column="0" Spacing="4">
            <TextBlock Text="Width" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"/>
            <TextBox Text="{Binding DesktopWidth}" Watermark="1920"
                     FontFamily="{DynamicResource FontMono}"
                     Background="{DynamicResource BgSurfaceBrush}" CornerRadius="6"/>
          </StackPanel>
          <StackPanel Grid.Column="1" Spacing="4">
            <TextBlock Text="Height" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"/>
            <TextBox Text="{Binding DesktopHeight}" Watermark="1080"
                     FontFamily="{DynamicResource FontMono}"
                     Background="{DynamicResource BgSurfaceBrush}" CornerRadius="6"/>
          </StackPanel>
        </Grid>

        <CheckBox Content="Enable drive redirection"
                  IsChecked="{Binding EnableDriveRedirection}"
                  IsVisible="{Binding IsRdp}"
                  Foreground="{DynamicResource TextSecondaryBrush}" FontSize="13"/>
        <CheckBox Content="Enable RemoteFX / AVC444"
                  IsChecked="{Binding EnableRemoteFx}"
                  IsVisible="{Binding IsRdp}"
                  Foreground="{DynamicResource TextSecondaryBrush}" FontSize="13"/>

      </StackPanel>
    </Expander>

    <!-- Actions -->
    <Grid ColumnDefinitions="*,*" ColumnSpacing="12" Margin="0,8,0,0">
      <Button Grid.Column="0" Content="Cancel"
              Background="{DynamicResource BgSurfaceBrush}"
              Foreground="{DynamicResource TextPrimaryBrush}"
              CornerRadius="6" HorizontalAlignment="Stretch"
              HorizontalContentAlignment="Center" Padding="0,10"
              Click="OnCancel"/>
      <Button Grid.Column="1" Content="Save &amp; Connect"
              Classes="primary-button"
              HorizontalAlignment="Stretch"
              IsEnabled="{Binding IsValid}"
              Click="OnSave"/>
    </Grid>

  </StackPanel>
</Window>
