<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:SpotDesk.UI.ViewModels"
        xmlns:views="using:SpotDesk.UI.Views"
        xmlns:controls="using:SpotDesk.UI.Controls"
        xmlns:local="using:SpotDesk.UI.Views"
        x:Class="SpotDesk.UI.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="SpotDesk"
        MinWidth="900" MinHeight="600"
        Background="{DynamicResource BgBaseBrush}"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="NoChrome"
        ExtendClientAreaTitleBarHeightHint="40">

  <Window.KeyBindings>
    <KeyBinding Gesture="Ctrl+K" Command="{Binding OpenSearchCommand}"/>
    <KeyBinding Gesture="Ctrl+N" Command="{Binding NewConnectionCommand}"/>
    <KeyBinding Gesture="Ctrl+OemBackslash" Command="{Binding ToggleSidebarCommand}"/>
    <KeyBinding Gesture="Ctrl+W" Command="{Binding ActiveTab.CloseCommand}"/>
    <KeyBinding Gesture="Ctrl+R" Command="{Binding ActiveTab.ReconnectCommand}"/>
    <KeyBinding Gesture="Ctrl+OemComma" Command="{Binding OpenSettingsCommand}"/>
    <KeyBinding Gesture="Ctrl+Shift+S" Command="{Binding ForceSyncCommand}"/>
    <KeyBinding Gesture="Ctrl+D1" Command="{Binding SwitchToTab1Command}"/>
    <KeyBinding Gesture="Ctrl+D2" Command="{Binding SwitchToTab2Command}"/>
    <KeyBinding Gesture="Ctrl+D3" Command="{Binding SwitchToTab3Command}"/>
    <KeyBinding Gesture="Ctrl+D4" Command="{Binding SwitchToTab4Command}"/>
    <KeyBinding Gesture="Ctrl+D5" Command="{Binding SwitchToTab5Command}"/>
    <KeyBinding Gesture="Ctrl+D6" Command="{Binding SwitchToTab6Command}"/>
    <KeyBinding Gesture="Ctrl+D7" Command="{Binding SwitchToTab7Command}"/>
    <KeyBinding Gesture="Ctrl+D8" Command="{Binding SwitchToTab8Command}"/>
    <KeyBinding Gesture="Ctrl+D9" Command="{Binding SwitchToTab9Command}"/>
  </Window.KeyBindings>

  <Window.Styles>
    <!-- Window chrome hover states -->
    <Style Selector="Button#CloseButton:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#C42B1C"/>
    </Style>
    <Style Selector="Button#CloseButton:pointerover TextBlock">
      <Setter Property="Foreground" Value="White"/>
    </Style>
    <Style Selector="Button#MinimizeButton:pointerover /template/ ContentPresenter,
                     Button#MaximizeButton:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource BgHoverBrush}"/>
    </Style>
  </Window.Styles>

  <Grid RowDefinitions="40,40,*">

    <!-- TITLE BAR (40px) — drag region + app identity + chrome -->
    <Border Grid.Row="0"
            x:Name="TitleBar"
            Background="{DynamicResource BgSurfaceBrush}"
            BorderBrush="{DynamicResource BorderSubtleBrush}"
            BorderThickness="0,0,0,1">
      <Grid ColumnDefinitions="Auto,*,Auto">

        <!-- App name (no hamburger — sidebar toggle lives in activity strip) -->
        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Spacing="8" Margin="12,0">
          <Image x:Name="TitleBarIcon" Width="18" Height="18" VerticalAlignment="Center"/>
          <TextBlock Text="SpotDesk" FontSize="14" FontWeight="SemiBold"
                     Foreground="{DynamicResource TextPrimaryBrush}"
                     VerticalAlignment="Center"/>
        </StackPanel>

        <!-- Drag area (empty — BeginMoveDrag wired in code-behind) -->
        <Border Grid.Column="1"/>

        <!-- App buttons + window chrome -->
        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Stretch" Spacing="0" Margin="4,0,0,0">
          <Button Classes="ghost-button" Command="{Binding ForceSyncCommand}"
                  ToolTip.Tip="Sync vault (Ctrl+Shift+S)" Margin="0,0,4,0">
            <TextBlock Text="↑" FontSize="14"/>
          </Button>
          <Button Classes="ghost-button" Command="{Binding OpenSettingsCommand}"
                  ToolTip.Tip="Settings (Ctrl+,)" Margin="0,0,8,0">
            <TextBlock Text="⚙" FontSize="14"/>
          </Button>

          <!-- Separator -->
          <Border Width="1" Margin="0,8" Background="{DynamicResource BorderSubtleBrush}"/>

          <!-- Min / Max / Close -->
          <Button x:Name="MinimizeButton"
                  Width="46" Height="40"
                  Background="Transparent" BorderThickness="0"
                  CornerRadius="0"
                  ToolTip.Tip="Minimize">
            <TextBlock Text="&#x2015;" FontSize="18" HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource TextSecondaryBrush}"/>
          </Button>
          <Button x:Name="MaximizeButton"
                  Width="46" Height="40"
                  Background="Transparent" BorderThickness="0"
                  CornerRadius="0"
                  ToolTip.Tip="Maximize / Restore">
            <TextBlock x:Name="MaximizeIcon" Text="&#x25A1;" FontSize="16"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource TextSecondaryBrush}"/>
          </Button>
          <Button x:Name="CloseButton"
                  Width="46" Height="40"
                  Background="Transparent" BorderThickness="0"
                  CornerRadius="0"
                  ToolTip.Tip="Close">
            <TextBlock Text="&#x2715;" FontSize="16" HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource TextSecondaryBrush}"/>
          </Button>
        </StackPanel>
      </Grid>
    </Border>

    <!-- TAB BAR (40px) — dedicated row below title bar -->
    <Border Grid.Row="1"
            Background="{DynamicResource BgSurfaceBrush}"
            BorderBrush="{DynamicResource BorderSubtleBrush}"
            BorderThickness="0,0,0,1">
      <ScrollViewer HorizontalScrollBarVisibility="Auto"
                    VerticalScrollBarVisibility="Disabled">
        <StackPanel Orientation="Horizontal" VerticalAlignment="Stretch">
          <Button Classes="ghost-button" Command="{Binding NewConnectionCommand}"
                  Margin="4,0" ToolTip.Tip="New connection (Ctrl+N)"
                  VerticalAlignment="Center">
            <TextBlock Text="+ New" FontSize="13"/>
          </Button>
          <!-- Thin vertical separator -->
          <Border Width="1" Margin="4,10" Background="{DynamicResource BorderSubtleBrush}"/>
          <ItemsControl ItemsSource="{Binding Tabs}">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate>
                <StackPanel Orientation="Horizontal"/>
              </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="vm:SessionTabViewModel">
                <controls:SessionTab/>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>
      </ScrollViewer>
    </Border>

    <!-- CONTENT AREA with activity strip + sidebar overlay support -->
    <Grid Grid.Row="2" ColumnDefinitions="36,*">

      <!-- Activity strip — always-visible left bar for sidebar toggle/pin -->
      <Border Grid.Column="0"
              Background="{DynamicResource BgSurfaceBrush}"
              BorderBrush="{DynamicResource BorderSubtleBrush}"
              BorderThickness="0,0,1,0">
        <StackPanel VerticalAlignment="Top" Margin="0,8,0,0" Spacing="4">
          <!-- Sidebar toggle -->
          <Button Classes="ghost-button"
                  Width="36" Height="36" Padding="0"
                  ToolTip.Tip="Toggle sidebar (Ctrl+\)"
                  Command="{Binding ToggleSidebarCommand}">
            <TextBlock Text="⬜" FontSize="13"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource TextSecondaryBrush}"/>
          </Button>
          <!-- Pin indicator -->
          <Button Classes="ghost-button"
                  Width="36" Height="36" Padding="0"
                  ToolTip.Tip="Pin/unpin sidebar"
                  Command="{Binding ToggleSidebarPinCommand}">
            <TextBlock Text="{Binding SidebarPinIcon}"
                       FontSize="12"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource TextTertiaryBrush}"/>
          </Button>
        </StackPanel>
      </Border>

      <!-- Main area: sidebar + content -->
      <Panel Grid.Column="1">

      <!-- Pinned layout: sidebar + resize handle + content -->
      <Grid x:Name="ContentGrid" ColumnDefinitions="Auto,4,*">

        <!-- Sidebar (pinned mode) -->
        <Border Grid.Column="0"
                Width="{Binding EffectiveSidebarWidth}"
                MinWidth="0" MaxWidth="520"
                Background="{DynamicResource BgSurfaceBrush}"
                BorderBrush="{DynamicResource BorderSubtleBrush}"
                BorderThickness="0,0,1,0">
          <views:SidebarView DataContext="{Binding ConnectionTree}"
                             IsVisible="{Binding IsSidebarPinned}"/>
        </Border>

        <!-- Resize handle (pinned + visible only) -->
        <Border Grid.Column="1"
                x:Name="SidebarResizeHandle"
                Background="{DynamicResource BorderSubtleBrush}"
                Cursor="SizeWestEast"
                Opacity="0.4"
                IsVisible="{Binding IsSidebarPinned}"/>

        <!-- Content -->
        <Grid Grid.Column="2" Background="{DynamicResource BgBaseBrush}">
          <views:WelcomeView IsVisible="{Binding IsWelcomeVisible}"/>
          <!-- Active session view rendered by SessionTabView -->
          <ContentControl Content="{Binding ActiveTab}"
                          IsVisible="{Binding !IsWelcomeVisible}">
            <ContentControl.ContentTemplate>
              <local:SessionViewSelector/>
            </ContentControl.ContentTemplate>
          </ContentControl>
        </Grid>
      </Grid>

      <!-- Overlay backdrop (unpinned + open) -->
      <Border ZIndex="9"
              Background="#60000000"
              IsVisible="{Binding IsSidebarOverlayOpen}"
              x:Name="SidebarBackdrop"/>

      <!-- Overlay sidebar (unpinned + open) -->
      <Border ZIndex="10"
              Width="{Binding SidebarWidth}"
              HorizontalAlignment="Left"
              IsVisible="{Binding IsSidebarOverlayOpen}"
              Background="{DynamicResource BgSurfaceBrush}"
              BorderBrush="{DynamicResource BorderSubtleBrush}"
              BorderThickness="0,0,1,0">
        <views:SidebarView DataContext="{Binding ConnectionTree}"/>
      </Border>

      </Panel>

    </Grid>
  </Grid>

</Window>
