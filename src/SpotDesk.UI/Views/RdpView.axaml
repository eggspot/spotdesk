<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:SpotDesk.UI.ViewModels"
             x:Class="SpotDesk.UI.Views.RdpView"
             x:DataType="vm:SessionTabViewModel">

  <Grid RowDefinitions="Auto,*,24">

    <!-- Session toolbar — always visible -->
    <Border Grid.Row="0"
            Background="{DynamicResource BgSurfaceBrush}"
            BorderBrush="{DynamicResource BorderSubtleBrush}"
            BorderThickness="0,0,0,1"
            Padding="8,6">
      <StackPanel Orientation="Horizontal" Spacing="4">
        <Button Classes="ghost-button" Content="Fit Window"   x:Name="BtnFitWindow"  FontSize="12"
                Command="{Binding FitWindowCommand}"/>
        <Button Classes="ghost-button" Content="Full Screen"  x:Name="BtnFullScreen" FontSize="12"
                ToolTip.Tip="Ctrl+Shift+F"/>
        <Button Classes="ghost-button" Content="Screenshot"   x:Name="BtnScreenshot" FontSize="12"
                Command="{Binding TakeScreenshotCommand}"/>
        <Button Classes="ghost-button" Content="Ctrl+Alt+Del" x:Name="BtnCtrlAltDel" FontSize="12"
                Command="{Binding SendCtrlAltDelCommand}"/>
        <Button Classes="ghost-button" Content="Disconnect"
                Command="{Binding DisconnectCommand}" FontSize="12"/>
      </StackPanel>
    </Border>

    <!-- RDP session surface — framebuffer rendered as Image -->
    <Border Grid.Row="1" Background="#0A0A0A">
      <Image x:Name="SessionImage"
             Stretch="Fill"
             HorizontalAlignment="Stretch"
             VerticalAlignment="Stretch"/>
    </Border>

    <!-- Connecting overlay (ZIndex=3) -->
    <Border Grid.Row="1" ZIndex="3"
            Background="{DynamicResource BgBaseBrush}"
            IsVisible="{Binding IsConnecting}">
      <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="16">
        <TextBlock Text="⟳"
                   FontSize="36"
                   Foreground="{DynamicResource AccentPrimaryBrush}"
                   HorizontalAlignment="Center"/>
        <TextBlock Text="{Binding DisplayName, StringFormat='Connecting to {0}…'}"
                   FontSize="15" FontWeight="Medium"
                   Foreground="{DynamicResource TextPrimaryBrush}"
                   HorizontalAlignment="Center"/>
        <TextBlock Text="{Binding StatusMessage}"
                   FontSize="13"
                   Foreground="{DynamicResource TextSecondaryBrush}"
                   HorizontalAlignment="Center"/>
      </StackPanel>
    </Border>

    <!-- Error overlay (ZIndex=4) — shown when error and not auto-reconnecting -->
    <Border Grid.Row="1" ZIndex="4"
            Background="{DynamicResource BgBaseBrush}"
            IsVisible="{Binding IsError}">
      <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="16">
        <TextBlock Text="⚠"
                   FontSize="40"
                   Foreground="#EF4444"
                   HorizontalAlignment="Center"/>
        <TextBlock Text="Connection Failed"
                   FontSize="17" FontWeight="SemiBold"
                   Foreground="{DynamicResource TextPrimaryBrush}"
                   HorizontalAlignment="Center"/>
        <TextBlock Text="{Binding StatusMessage}"
                   FontSize="13"
                   Foreground="{DynamicResource TextSecondaryBrush}"
                   HorizontalAlignment="Center"
                   TextWrapping="Wrap"
                   MaxWidth="360"
                   TextAlignment="Center"/>
        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center" Margin="0,8,0,0">
          <Button Classes="primary-button" Content="Retry"
                  Command="{Binding ReconnectCommand}"/>
          <Button Content="Close Tab"
                  Background="{DynamicResource BgElevatedBrush}"
                  Foreground="{DynamicResource TextPrimaryBrush}"
                  BorderThickness="1" BorderBrush="{DynamicResource BorderSubtleBrush}"
                  CornerRadius="6" Padding="16,8"
                  Command="{Binding CloseCommand}"/>
        </StackPanel>
      </StackPanel>
    </Border>

    <!-- Auto-reconnect overlay (ZIndex=5) — overlaps error overlay -->
    <Border Grid.Row="1" ZIndex="5"
            Background="{DynamicResource BgBaseBrush}"
            IsVisible="{Binding IsReconnecting}">
      <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="12">
        <TextBlock Text="Connection lost"
                   FontSize="16" FontWeight="Medium"
                   Foreground="{DynamicResource TextPrimaryBrush}"
                   HorizontalAlignment="Center"/>
        <TextBlock Text="{Binding ReconnectCountdown, StringFormat='Reconnecting in {0}s…'}"
                   FontSize="13"
                   Foreground="{DynamicResource TextSecondaryBrush}"
                   HorizontalAlignment="Center"/>
        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
          <Button Classes="primary-button" Content="Reconnect now"
                  Command="{Binding ReconnectCommand}"/>
          <Button Content="Cancel"
                  Background="{DynamicResource BgElevatedBrush}"
                  Foreground="{DynamicResource TextPrimaryBrush}"
                  CornerRadius="6" Padding="16,8"
                  Command="{Binding CancelReconnectCommand}"/>
        </StackPanel>
      </StackPanel>
    </Border>

    <!-- Idle placeholder (ZIndex=2) — shown before first connect -->
    <Border Grid.Row="1" ZIndex="2"
            Background="{DynamicResource BgBaseBrush}"
            IsVisible="{Binding IsIdle}">
      <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="12">
        <TextBlock Text="□"
                   FontSize="40"
                   Foreground="{DynamicResource TextTertiaryBrush}"
                   HorizontalAlignment="Center"/>
        <TextBlock Text="{Binding DisplayName}"
                   FontSize="16" FontWeight="Medium"
                   Foreground="{DynamicResource TextPrimaryBrush}"
                   HorizontalAlignment="Center"/>
        <Button Classes="primary-button" Content="Connect"
                Command="{Binding ConnectCommand}"
                HorizontalAlignment="Center"/>
      </StackPanel>
    </Border>

    <!-- Status bar -->
    <Border Grid.Row="2"
            Background="{DynamicResource BgSurfaceBrush}"
            BorderBrush="{DynamicResource BorderSubtleBrush}"
            BorderThickness="0,1,0,0"
            Padding="12,0">
      <Grid ColumnDefinitions="12,*,Auto">
        <Ellipse Grid.Column="0" Width="7" Height="7"
                 Fill="{Binding StatusColor, Converter={StaticResource ColorStringToBrushConverter}}"
                 VerticalAlignment="Center"/>
        <TextBlock Grid.Column="1" FontSize="12"
                   Foreground="{DynamicResource TextSecondaryBrush}"
                   VerticalAlignment="Center"
                   Margin="6,0,0,0"
                   Text="{Binding StatusMessage}"/>
        <TextBlock Grid.Column="2" FontSize="12"
                   Foreground="{Binding LatencyMs, Converter={StaticResource LatencyColorConverter}}"
                   VerticalAlignment="Center"
                   Text="{Binding LatencyMs, StringFormat='{}{0}ms'}"
                   IsVisible="{Binding LatencyMs, Converter={x:Static ObjectConverters.IsNotNull}}"/>
      </Grid>
    </Border>
  </Grid>

</UserControl>
