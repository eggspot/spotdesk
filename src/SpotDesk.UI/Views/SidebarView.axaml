<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:SpotDesk.UI.ViewModels"
             xmlns:controls="using:SpotDesk.UI.Controls"
             x:Class="SpotDesk.UI.Views.SidebarView"
             x:DataType="vm:ConnectionTreeViewModel">

  <Grid RowDefinitions="44,Auto,*,Auto">

    <!-- Sidebar header -->
    <Grid Grid.Row="0" ColumnDefinitions="*,Auto"
          Margin="14,0"
          VerticalAlignment="Center">
      <TextBlock Grid.Column="0"
                 Text="CONNECTIONS"
                 FontSize="11" FontWeight="SemiBold"
                 Foreground="{DynamicResource TextTertiaryBrush}"
                 LetterSpacing="2"
                 VerticalAlignment="Center"/>
      <Button Grid.Column="1"
              Classes="ghost-button"
              ToolTip.Tip="Reconnect all disconnected sessions"
              Command="{Binding ReconnectAllCommand}"
              Padding="6">
        <TextBlock Text="⟳" FontSize="15"
                   Foreground="{DynamicResource TextSecondaryBrush}"/>
      </Button>
    </Grid>

    <!-- Search box -->
    <Border Grid.Row="1" Margin="8,0,8,6" Padding="8,7"
            Background="{DynamicResource BgElevatedBrush}"
            CornerRadius="6"
            BorderBrush="{DynamicResource BorderSubtleBrush}"
            BorderThickness="1">
      <StackPanel Orientation="Horizontal" Spacing="6">
        <TextBlock Text="⌕" FontSize="14" Foreground="{DynamicResource TextTertiaryBrush}"
                   VerticalAlignment="Center"/>
        <TextBox Text="{Binding SearchQuery}"
                 Watermark="Search...  Ctrl+K"
                 Background="Transparent"
                 BorderThickness="0"
                 FontSize="13"
                 Foreground="{DynamicResource TextPrimaryBrush}"
                 VerticalAlignment="Center"
                 HorizontalAlignment="Stretch"/>
      </StackPanel>
    </Border>

    <!-- Connection tree -->
    <ScrollViewer Grid.Row="2">
      <ItemsControl ItemsSource="{Binding Groups}">
        <ItemsControl.ItemTemplate>
          <DataTemplate x:DataType="vm:ConnectionGroupViewModel">
            <controls:ConnectionGroupItem/>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </ScrollViewer>

    <!-- Add connection button -->
    <Button Grid.Row="3" Classes="ghost-button"
            Margin="8,4" HorizontalAlignment="Stretch"
            HorizontalContentAlignment="Stretch"
            Command="{Binding NewConnectionCommand}">
      <TextBlock Text="+ Add Connection" FontSize="13"
                 Foreground="{DynamicResource TextSecondaryBrush}"/>
    </Button>

  </Grid>
</UserControl>
