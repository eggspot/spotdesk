<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="using:SpotDesk.Core.Models"
             xmlns:conv="using:SpotDesk.UI.Converters"
             x:Class="SpotDesk.UI.Controls.ConnectionListItem"
             x:DataType="models:ConnectionEntry">

  <Grid ColumnDefinitions="24,*,Auto" Height="46"
        Background="Transparent" Cursor="Hand">
    <Grid.Styles>
      <Style Selector="Grid:pointerover">
        <Setter Property="Background" Value="{DynamicResource BgHoverBrush}"/>
      </Style>
    </Grid.Styles>

    <!-- Status dot -->
    <Ellipse Grid.Column="0" Width="8" Height="8"
             Fill="{DynamicResource StatusIdleBrush}"
             VerticalAlignment="Center"
             Margin="8,0,0,0"/>

    <!-- Name + host -->
    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,0">
      <TextBlock Text="{Binding Name}" FontSize="15"
                 Foreground="{DynamicResource TextPrimaryBrush}"
                 TextTrimming="CharacterEllipsis"/>
      <TextBlock Text="{Binding Host}" FontSize="12"
                 Foreground="{DynamicResource TextTertiaryBrush}"
                 FontFamily="{DynamicResource FontMono}"/>
    </StackPanel>

    <!-- Protocol badge -->
    <Border Grid.Column="2"
            Background="{Binding Protocol, Converter={x:Static conv:ProtocolColorConverter.Instance}}"
            CornerRadius="3" Padding="4,1" Margin="4,0,8,0">
      <TextBlock Text="{Binding Protocol, Converter={x:Static conv:ProtocolLabelConverter.Instance}}"
                 FontSize="9" Foreground="White" FontWeight="Bold" LetterSpacing="0.5"/>
    </Border>
  </Grid>

</UserControl>
